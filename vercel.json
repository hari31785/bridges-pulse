{
  "version": 2,
  "builds": [
    { "src": "server/app.js", "use": "@vercel/node" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server/app.js" }
  ]
}
